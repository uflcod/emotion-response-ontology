     -->

    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000000 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007610"/>
        <obo:IAO_0000115>A behavioral response that includes overt action, cognitive response, verbal response, or physiological reaction in response to a situation or event, or internal process which evokes positive feelings, negative feelings, or surprise (i.e., emotional experiences).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T20:50:19Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000000</oboInOwl:id>
        <rdfs:label>emotion process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000001 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0050890"/>
        <obo:IAO_0000115>A cognitive process during which an organism is aware of something either internal or external to itself.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T20:52:17Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000001</oboInOwl:id>
        <rdfs:label>phenomenal cognitive experience</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000001"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A cognitive process during which an organism is aware of something either internal or external to itself.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/consciousness</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000002 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000002">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.bioontology.org/ontology/EMRO/0000001"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                        <owl:someValuesFrom rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <obo:IAO_0000115>A phenomenal cognitive experience evaluated as pleasant or unpleasant.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T20:52:39Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000002</oboInOwl:id>
        <rdfs:label>emotional experience (feeling)</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000002"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A phenomenal cognitive experience evaluated as pleasant or unpleasant.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/feeling</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000003 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000003">
        <rdfs:subClassOf rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
        <obo:IAO_0000115>An emotion process that is a response that occurs more distally in time or physical space with regard to threatening stimuli. Anxiety typically involves worrying about experiencing threats that could or will be experienced in the future.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T20:56:47Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000003</oboInOwl:id>
        <rdfs:label>anxiety process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000004 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000004">
        <rdfs:subClassOf rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
        <obo:IAO_0000115>An emotion process that is an in-the-moment response to a perceived threat. Fear is typically associated with organized, robust visceral arousal.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T20:57:08Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000004</oboInOwl:id>
        <rdfs:label>fear process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000005 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000005">
        <rdfs:subClassOf rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000001"/>
        <obo:IAO_0000115>A phenomenal cognitive experience produced by the parts of the nervous sysem involved in awarness of the external world (i.e., external stimulus) or changes internal organs associated with processes such as hunger, thirst, nausea, and sexual excitement. A sensory experience does not necessarily entail the existence phenomenon experiences (e.g., hallucinations).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T20:59:47Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000005</oboInOwl:id>
        <rdfs:label>sensory experience</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000005"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A phenomenal cognitive experience produced by the parts of the nervous sysem involved in awarness of the external world (i.e., external stimulus) or changes internal organs associated with processes such as hunger, thirst, nausea, and sexual excitement. A sensory experience does not necessarily entail the existence phenomenon experiences (e.g., hallucinations).</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/sensation</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000006 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0061744"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0006936"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A motor behavior that happens as a response to an emotion process. The motoric response includes muscle contractions that may move parts of the body or prevent the body from moving (e.g., freezing).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T21:02:42Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000006</oboInOwl:id>
        <rdfs:label>motoric response to emotion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000007 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007610"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A psychophysiological process that is part of an emotion process.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T21:10:13Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000007</oboInOwl:id>
        <rdfs:label>psychophysiological response to emotion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000008 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0160269"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Sweat screation that happens as a response to an emotion process.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T22:22:47Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000008</oboInOwl:id>
        <rdfs:label>sweat secretion response to emotion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000009 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000009">
        <rdfs:subClassOf rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000035"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-03-17T19:27:16Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000009</oboInOwl:id>
        <rdfs:label>positive emotional valence</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000010 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0006936"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Muscle contraction that happens as a response to an emotion process.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T22:36:17Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000010</oboInOwl:id>
        <rdfs:label>muscle tension response to emotion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000011 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000011">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0003015"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A heart process during which the rate at which the heart beats increases as a response to an emotion process.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T22:39:24Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000011</oboInOwl:id>
        <rdfs:label>increased heart response to emotion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000012 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0003016"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A respiratory system process during which the rate  at which an organism moves air in and out of its lungs increases as a response to an emotion process.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-11-24T22:44:09Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000012</oboInOwl:id>
        <rdfs:label>increased breathing rate response to emotion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000013 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000013">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0050890"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A cognitive process that happens as a response to an emotion process.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-12-17T17:11:45Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000013</oboInOwl:id>
        <rdfs:label>cognitive response to emotion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000014 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000014">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0050890"/>
        <obo:IAO_0000115>A cognitive process during which the nature and significance of a phenomenon or event is evaluated.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-12-17T17:18:23Z</terms:created>
        <oboInOwl:id>http://purl.bioontology.org/ontology/EMRO/0000014</oboInOwl:id>
        <rdfs:label>cognitive appraisal process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.bioontology.org/ontology/EMRO/0000015 -->

    <owl:Class rdf:about="http://purl.bioontology.org/ontology/EMRO/0000015">
        <rdfs:subClassOf rdf:resource="http://purl.bioontology.org/ontology/EMRO/0000007"/>
        <obo:IAO_0000115>A transient loss of consciousness and postural tone that happens as a result of an emotion process.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
