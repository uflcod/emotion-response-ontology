        <obo:IAO_0000115>The internally coordinated responses (actions or inactions) of animals (individuals or groups) to internal or external stimuli, via a mechanism that involves nervous system activity.</obo:IAO_0000115>
        <emro-non-classified:isDefinedBy rdf:resource="http://purl.obolibrary.org/obo/go.owl"/>
        <oboInOwl:created_by>jl</oboInOwl:created_by>
        <oboInOwl:creation_date>2012-09-20T14:06:08Z</oboInOwl:creation_date>
