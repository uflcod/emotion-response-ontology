    <!-- http://purl.obolibrary.org/obo/BFO_0000015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/BFO_0000015">
        <obo:BFO_0000179>process</obo:BFO_0000179>
        <obo:BFO_0000180>Process</obo:BFO_0000180>
        <obo:IAO_0000112>a process of cell-division, \ a beating of the heart</obo:IAO_0000112>
        <obo:IAO_0000112>a process of meiosis</obo:IAO_0000112>
        <obo:IAO_0000112>a process of sleeping</obo:IAO_0000112>
        <obo:IAO_0000112>the course of a disease</obo:IAO_0000112>
        <obo:IAO_0000112>the flight of a bird</obo:IAO_0000112>
        <obo:IAO_0000112>the life of an organism</obo:IAO_0000112>
        <obo:IAO_0000112>your process of aging.</obo:IAO_0000112>
        <obo:IAO_0000115>p is a process = Def. p is an occurrent that has temporal proper parts and for some time t, p s-depends_on some material entity at t. (axiom label in BFO2 Reference: [083-003])</obo:IAO_0000115>
        <obo:IAO_0000602>(iff (Process a) (and (Occurrent a) (exists (b) (properTemporalPartOf b a)) (exists (c t) (and (MaterialEntity c) (specificallyDependsOnAt a c t))))) // axiom label in BFO2 CLIF: [083-003] </obo:IAO_0000602>
        <emro-non-classified:isDefinedBy rdf:resource="http://purl.obolibrary.org/obo/bfo.owl"/>
        <oboInOwl:id>BFO:0000015</oboInOwl:id>
        <rdfs:label>process</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
