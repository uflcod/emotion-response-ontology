        <oboInOwl:hasExactSynonym>localisation</oboInOwl:hasExactSynonym>
        <oboInOwl:hasNarrowSynonym>establishment and maintenance of cellular component location</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym>establishment and maintenance of substance location</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym>establishment and maintenance of substrate location</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>single organism localization</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>single-organism localization</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>GO:0051179</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/http://purl.bioontology.org/ontology/emro/emro-non-classified.owl#gocheck_do_not_annotate"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/http://purl.bioontology.org/ontology/emro/emro-non-classified.owl#goslim_pir"/>
