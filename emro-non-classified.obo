property_value: isDefinedBy http://purl.obolibrary.org/obo/ro.owl
property_value: seeAlso "https://wiki.geneontology.org/Has_output" xsd:anyURI
is_a: RO:0000057 ! has participant
inverse_of: RO:0002353 ! output of

