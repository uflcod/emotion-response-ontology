    <!-- http://purl.obolibrary.org/obo/GO_0007585 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GO_0007585">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0032501"/>
        <obo:IAO_0000115>The process of gaseous exchange between an organism and its environment. In plants, microorganisms, and many small animals, air or water makes direct contact with the organism&apos;s cells or tissue fluids, and the processes of diffusion supply the organism with dioxygen (O2) and remove carbon dioxide (CO2). In larger animals the efficiency of gaseous exchange is improved by specialized respiratory organs, such as lungs and gills, which are ventilated by breathing mechanisms.</obo:IAO_0000115>
        <emro-non-classified:isDefinedBy rdf:resource="http://purl.obolibrary.org/obo/go.owl"/>
        <oboInOwl:hasBroadSynonym>breathing</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>respiration</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
        <oboInOwl:id>GO:0007585</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/http://purl.bioontology.org/ontology/emro/emro-non-classified.owl#goslim_chembl"/>
        <rdfs:label>respiratory gaseous exchange by respiratory system</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/GO_0007585"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>The process of gaseous exchange between an organism and its environment. In plants, microorganisms, and many small animals, air or water makes direct contact with the organism&apos;s cells or tissue fluids, and the processes of diffusion supply the organism with dioxygen (O2) and remove carbon dioxide (CO2). In larger animals the efficiency of gaseous exchange is improved by specialized respiratory organs, such as lungs and gills, which are ventilated by breathing mechanisms.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>ISBN:0198506732</oboInOwl:hasDbXref>
    </owl:Axiom>
    


