# Class: <http://purl.obolibrary.org/obo/EMRO_0000009> (positive emotional valence)

AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> "https://dictionary.apa.org/emotional-valence") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/EMRO_0000009> "An emotional valence which is inherently pleasant or attractive."@en)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/EMRO_0000009> <https://orcid.org/0000-0001-9625-1899>)
AnnotationAssertion(<http://purl.org/dc/terms/created> <http://purl.obolibrary.org/obo/EMRO_0000009> "2026-03-17T19:27:16Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/EMRO_0000009> "Emotional valences exist on a continuum from pleasant to unpleasant, or from attractive to aversive."@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/EMRO_0000009> "positive emotional valence")
SubClassOf(<http://purl.obolibrary.org/obo/EMRO_0000009> <http://purl.obolibrary.org/obo/EMRO_0000035>)

