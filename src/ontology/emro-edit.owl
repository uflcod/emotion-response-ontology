# Class: <http://purl.obolibrary.org/obo/GO_0007610> (behavior)

AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#prefLabel> <http://purl.obolibrary.org/obo/GO_0007610> "behavioral response to stimulus")

# Class: <http://purl.obolibrary.org/obo/GO_0050890> (cognition)

AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#prefLabel> <http://purl.obolibrary.org/obo/GO_0050890> "cognitive process")

# Class: <http://purl.bioontology.org/ontology/EMRO_0000000> (emotion process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.bioontology.org/ontology/EMRO_0000000> "A behavioral response that includes overt action, cognitive response, verbal response, or physiological reaction in response to a situation or event, or internal process which evokes positive feelings, negative feelings, or surprise (i.e., emotional experiences).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000000> <https://orcid.org/0000-0001-9625-1899>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000000> <https://orcid.org/0000-0001-9990-8331>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000000> <https://orcid.org/0000-0002-0766-8455>)
AnnotationAssertion(<http://purl.org/dc/terms/created> <http://purl.bioontology.org/ontology/EMRO_0000000> "2025-11-24T20:50:19Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/EMRO_0000000> "emotion process"@en)
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000000> <http://purl.obolibrary.org/obo/GO_0007610>)

# Class: <http://purl.bioontology.org/ontology/EMRO_0000001> (phenomenal cognitive experience)

AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> "https://dictionary.apa.org/consciousness") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.bioontology.org/ontology/EMRO_0000001> "A cognitive process during which an organism is aware of something either internal or external to itself.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000001> <https://orcid.org/0000-0001-9625-1899>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000001> <https://orcid.org/0000-0001-9990-8331>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000001> <https://orcid.org/0000-0002-0766-8455>)
AnnotationAssertion(<http://purl.org/dc/terms/created> <http://purl.bioontology.org/ontology/EMRO_0000001> "2025-11-24T20:52:17Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/EMRO_0000001> "phenomenal cognitive experience"@en)
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000001> <http://purl.obolibrary.org/obo/GO_0050890>)

# Class: <http://purl.bioontology.org/ontology/EMRO_0000002> (emotional experience (feeling))

AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> "https://dictionary.apa.org/feeling") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.bioontology.org/ontology/EMRO_0000002> "A phenomenal cognitive experience evaluated as pleasant or unpleasant.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000002> <https://orcid.org/0000-0001-9625-1899>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000002> <https://orcid.org/0000-0001-9990-8331>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000002> <https://orcid.org/0000-0002-0766-8455>)
AnnotationAssertion(<http://purl.org/dc/terms/created> <http://purl.bioontology.org/ontology/EMRO_0000002> "2025-11-24T20:52:39Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/EMRO_0000002> "emotional experience (feeling)"@en)
EquivalentClasses(<http://purl.bioontology.org/ontology/EMRO_0000002> ObjectIntersectionOf(<http://purl.bioontology.org/ontology/EMRO_0000001> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.bioontology.org/ontology/EMRO_0000000>)))

# Class: <http://purl.bioontology.org/ontology/EMRO_0000003> (anxiety process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.bioontology.org/ontology/EMRO_0000003> "An emotion process that is a response that occurs more distally in time or physical space with regard to threatening stimuli. Anxiety typically involves worrying about experiencing threats that could or will be experienced in the future.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000003> <https://orcid.org/0000-0001-9625-1899>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000003> <https://orcid.org/0000-0001-9990-8331>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000003> <https://orcid.org/0000-0002-0766-8455>)
AnnotationAssertion(<http://purl.org/dc/terms/created> <http://purl.bioontology.org/ontology/EMRO_0000003> "2025-11-24T20:56:47Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/EMRO_0000003> "anxiety process"@en)
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000003> <http://purl.bioontology.org/ontology/EMRO_0000000>)

# Class: <http://purl.bioontology.org/ontology/EMRO_0000004> (fear process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.bioontology.org/ontology/EMRO_0000004> "An emotion process that is an in-the-moment response to a perceived threat. Fear is typically associated with organized, robust visceral arousal.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000004> <https://orcid.org/0000-0001-9625-1899>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000004> <https://orcid.org/0000-0001-9990-8331>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000004> <https://orcid.org/0000-0002-0766-8455>)
AnnotationAssertion(<http://purl.org/dc/terms/created> <http://purl.bioontology.org/ontology/EMRO_0000004> "2025-11-24T20:57:08Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/EMRO_0000004> "fear process"@en)
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000004> <http://purl.bioontology.org/ontology/EMRO_0000000>)

# Class: <http://purl.bioontology.org/ontology/EMRO_0000005> (sensory experience)

AnnotationAssertion(Annotation(<http://purl.obolibrary.org/obo/IAO_0000119> "https://dictionary.apa.org/sensation") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.bioontology.org/ontology/EMRO_0000005> "A phenomenal cognitive experience produced by the parts of the nervous sysem involved in awarness of the external world (i.e., external stimulus) or changes internal organs associated with processes such as hunger, thirst, nausea, and sexual excitement. A sensory experience does not necessarily entail the existence phenomenon experiences (e.g., hallucinations).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000005> <https://orcid.org/0000-0001-9625-1899>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000005> <https://orcid.org/0000-0001-9990-8331>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000005> <https://orcid.org/0000-0002-0766-8455>)
AnnotationAssertion(<http://purl.org/dc/terms/created> <http://purl.bioontology.org/ontology/EMRO_0000005> "2025-11-24T20:59:47Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/EMRO_0000005> "sensory experience"@en)
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000005> <http://purl.bioontology.org/ontology/EMRO_0000001>)

# Class: <http://purl.bioontology.org/ontology/EMRO_0000006> (motoric response to emotion)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.bioontology.org/ontology/EMRO_0000006> "A motor behavior that happens as a response to an emotion process. The motoric response includes muscle contractions that may move parts of the body or prevent the body from moving (e.g., freezing).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000006> <https://orcid.org/0000-0001-9625-1899>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000006> <https://orcid.org/0000-0001-9990-8331>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000006> <https://orcid.org/0000-0002-0766-8455>)
AnnotationAssertion(<http://purl.org/dc/terms/created> <http://purl.bioontology.org/ontology/EMRO_0000006> "2025-11-24T21:02:42Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/EMRO_0000006> "motoric response to emotion"@en)
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000006> <http://purl.obolibrary.org/obo/GO_0061744>)
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000006> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000051> <http://purl.obolibrary.org/obo/GO_0006936>))
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000006> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002410> <http://purl.bioontology.org/ontology/EMRO_0000000>))

# Class: <http://purl.bioontology.org/ontology/EMRO_0000007> (psychophysiological response to emotion)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.bioontology.org/ontology/EMRO_0000007> "A psychophysiological process that is part of an emotion process.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000007> <https://orcid.org/0000-0001-9625-1899>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000007> <https://orcid.org/0000-0001-9990-8331>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000007> <https://orcid.org/0000-0002-0766-8455>)
AnnotationAssertion(<http://purl.org/dc/terms/created> <http://purl.bioontology.org/ontology/EMRO_0000007> "2025-11-24T21:10:13Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.bioontology.org/ontology/EMRO_0000007> "psychophysiological response to emotion"@en)
EquivalentClasses(<http://purl.bioontology.org/ontology/EMRO_0000007> ObjectIntersectionOf(ObjectUnionOf(<http://purl.obolibrary.org/obo/GO_0003012> <http://purl.obolibrary.org/obo/GO_0003013> <http://purl.obolibrary.org/obo/GO_0003016> <http://purl.obolibrary.org/obo/GO_0050877> <http://purl.obolibrary.org/obo/GO_0061744> <http://purl.obolibrary.org/obo/GO_0160269>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002410> <http://purl.bioontology.org/ontology/EMRO_0000000>)))
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000007> <http://purl.obolibrary.org/obo/GO_0007610>)
SubClassOf(<http://purl.bioontology.org/ontology/EMRO_0000007> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.bioontology.org/ontology/EMRO_0000000>))

# Class: <http://purl.bioontology.org/ontology/EMRO_0000008> (sweat secretion response to emotion)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.bioontology.org/ontology/EMRO_0000008> "Sweat screation that happens as a response to an emotion process.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.bioontology.org/ontology/EMRO_0000008> <https://orcid.org/0000-0001-9625-1899>)
