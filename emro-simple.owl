        <rdfs:label xml:lang="en">avoidance behavior</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0003001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0003001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0000002"/>
        <obo:IAO_0000115 xml:lang="en">An emotional experience generated when events reflect on the worth or value of the self in one’s own or others’ eyes.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">self-conscious emotional experience (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T20:44:41Z</terms:created>
        <rdfs:label xml:lang="en">self-conscious emotional experience</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0003001"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An emotional experience generated when events reflect on the worth or value of the self in one’s own or others’ eyes.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/self-conscious-emotion</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0003002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0003002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0003001"/>
        <obo:IAO_0000115 xml:lang="en">A self-conscious emotional experience in which a person feels awkward or flustered in other people’s company or because of the attention of others, as, for example, when being observed engaging in actions that are subject to mild disapproval from others.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">embarrassment (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T20:47:27Z</terms:created>
        <rdfs:label xml:lang="en">embarrassment</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0003002"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A self-conscious emotional experience in which a person feels awkward or flustered in other people’s company or because of the attention of others, as, for example, when being observed engaging in actions that are subject to mild disapproval from others.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/embarrassment</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0003003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0003003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0003001"/>
        <obo:IAO_0000115 xml:lang="en">A highly unpleasant self-conscious emotional experience arising from the sense of there being something dishonorable, immodest, or indecorous in one’s own conduct or circumstances.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">shame (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T20:55:14Z</terms:created>
        <rdfs:label xml:lang="en">shame</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0003003"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A highly unpleasant self-conscious emotional experience arising from the sense of there being something dishonorable, immodest, or indecorous in one’s own conduct or circumstances.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/shame</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0003004 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0003004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0003001"/>
        <obo:IAO_0000115 xml:lang="en">A self-conscious emotional experience that occurs when a goal has been attained and one’s achievement has been recognized and approved by others.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">pride (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T20:57:07Z</terms:created>
        <rdfs:label xml:lang="en">pride</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0003004"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A self-conscious emotional experience that occurs when a goal has been attained and one’s achievement has been recognized and approved by others.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/pride</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0003005 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0003005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0003001"/>
        <obo:IAO_0000115 xml:lang="en">A self-conscious emotional experience characterized by a painful appraisal of having done (or thought) something that is wrong and often by a readiness to take action designed to undo or mitigate this wrong.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">guilt (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-04T20:58:18Z</terms:created>
        <rdfs:label xml:lang="en">guilt</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0003005"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A self-conscious emotional experience characterized by a painful appraisal of having done (or thought) something that is wrong and often by a readiness to take action designed to undo or mitigate this wrong.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/guilt</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004000 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004000">
        <obo:IAO_0000115 xml:lang="en">A process quality that characterizes a behavioral response to stimulus that is relatively stable, consistent, and enduring.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">personality triat characteristic (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-05T19:34:58Z</terms:created>
        <terms:description xml:lang="en">Personality triats are inferred from a pattern of behaviors, attitudes, feelings, and habits in the individual.</terms:description>
        <oboInOwl:hasExactSynonym>personality trait</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">personality trait characteristic</rdfs:label>
        <skos:prefLabel xml:lang="en">personality trait</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004000"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A process quality that characterizes a behavioral response to stimulus that is relatively stable, consistent, and enduring.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/personality-trait</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0000002"/>
        <obo:IAO_0000115 xml:lang="en">An emotional experience characterized by the presence of pleasant affect (e.g., feelings of happiness) versus the absence of unpleasant affect (e.g., depressed mood).</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">affective well-being (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T16:15:01Z</terms:created>
        <oboInOwl:hasExactSynonym>affective well-being</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">affective well-being</rdfs:label>
        <skos:prefLabel xml:lang="en">affective well-being</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004001"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An emotional experience characterized by the presence of pleasant affect (e.g., feelings of happiness) versus the absence of unpleasant affect (e.g., depressed mood).</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/affective-well-being</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0000000"/>
        <obo:IAO_0000115 xml:lang="en">An emotion process during which negative feelings arise from the perception that one is not spending enough time alone.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">aloneliness process (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T16:21:21Z</terms:created>
        <oboInOwl:hasExactSynonym>aloneliness</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">aloneliness process</rdfs:label>
        <skos:prefLabel xml:lang="en">aloneliness</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004000"/>
        <obo:IAO_0000115 xml:lang="en">A personality trait characteristic that is associated with  anxiety and inhibition in social situations.</obo:IAO_0000115>
        <obo:IAO_0000119 xml:lang="en">https://dictionary.apa.org/shyness</obo:IAO_0000119>
        <obo:IAO_0000589 xml:lang="en">shyness triat characteristic (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T16:26:11Z</terms:created>
        <terms:description xml:lang="en">It typically involves three components: (a) global feelings of emotional arousal and specific physiological experiences (e.g., pounding heart, sweating, blushing); (b) acute public self-consciousness, self-deprecation, and worries about being evaluated negatively by others; and (c) observable behavior such as quietness, gaze aversion, and social withdrawal.</terms:description>
        <oboInOwl:hasExactSynonym xml:lang="en">shyness</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">shyness trait characteristic</rdfs:label>
        <skos:prefLabel xml:lang="en">shyness</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004003"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A personality trait characteristic that is associated with  anxiety and inhibition in social situations.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/shyness</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004000"/>
        <obo:IAO_0000115 xml:lang="en">A personality trait characteristic involving an orientation toward the internal private world of one’s self and one’s inner thoughts and feelings, rather than toward the outer world of people and things.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">introversion triat characteristic (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T16:35:23Z</terms:created>
        <oboInOwl:hasExactSynonym xml:lang="en">introversion</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">introversion trait characteristic</rdfs:label>
        <skos:prefLabel xml:lang="en">introversion</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004007"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A personality trait characteristic involving an orientation toward the internal private world of one’s self and one’s inner thoughts and feelings, rather than toward the outer world of people and things.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/introversion</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004008 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004008">
        <obo:IAO_0000231>The term anxious withdrawal (or anxious solitude) is better suited in a more specific domain ontology, such as PHASES.</obo:IAO_0000231>
        <obo:IAO_0000589 xml:lang="en">anxious withdrawal triat characteristic (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T16:37:36Z</terms:created>
        <oboInOwl:hasExactSynonym xml:lang="en">anxious solitude</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">obsolete anxious withdrawal trait characteristic</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:prefLabel xml:lang="en">obsolete anxious withdrawal</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004009 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004009">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0000000"/>
        <obo:IAO_0000115 xml:lang="en">An emotion process involving a negative affective state, ranging from unhappiness and discontent to an extreme feeling of sadness, pessimism, and despondency, that interferes with daily life.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">depression process (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T16:40:11Z</terms:created>
        <oboInOwl:hasExactSynonym xml:lang="en">depression</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">depression process</rdfs:label>
        <skos:prefLabel xml:lang="en">depression</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004009"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An emotion process involving a negative affective state, ranging from unhappiness and discontent to an extreme feeling of sadness, pessimism, and despondency, that interferes with daily life.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/depression</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004010">
        <obo:IAO_0000115 xml:lang="en">A process quality characterizing the attitudes, values, and behaviors of a population or shared by a particular group within a society, such as a profession, social class, or age group.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">societal culture characteristic (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T17:03:30Z</terms:created>
        <terms:description xml:lang="en">The values, beliefs, language, rituals, traditions, and other behaviors that are passed from one generation to another within any social group. Broad definitions include any socially definable group with its own set of values, behaviors, and beliefs. Accordingly, cultural groups could include groups based on shared identities such as ethnicity.</terms:description>
        <oboInOwl:hasExactSynonym xml:lang="en">social culture</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">societal culture characteristic</rdfs:label>
        <skos:prefLabel xml:lang="en">culture</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004010"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A process quality characterizing the attitudes, values, and behaviors of a population or shared by a particular group within a society, such as a profession, social class, or age group.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/culture</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004011 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004011">
        <obo:IAO_0000115 xml:lang="en">A cognitive process during which an individual produces or develops original work, theories, techniques, or thoughts.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">creativity (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T17:06:26Z</terms:created>
        <oboInOwl:hasExactSynonym>creativity</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">creativity</rdfs:label>
        <skos:prefLabel xml:lang="en">creativity</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004011"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A cognitive process during which an individual produces or develops original work, theories, techniques, or thoughts.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/creativity</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004012 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0000000"/>
        <obo:IAO_0000115 xml:lang="en">An emotion process that is a physiological or psychological response to internal or external stressors.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">stress process (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T17:50:36Z</terms:created>
        <terms:description xml:lang="en">Stress involves changes affecting nearly every system of the body, influencing how people feel and behave.</terms:description>
        <oboInOwl:hasExactSynonym xml:lang="en">stress</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">stress process</rdfs:label>
        <skos:prefLabel xml:lang="en">stress</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004012"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An emotion process that is a physiological or psychological response to internal or external stressors.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/stress</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004013 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004013">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0000000"/>
        <obo:IAO_0000115 xml:lang="en">An emotion process involving voluntary or involuntary absence of contact with others.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">social isolation process (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T18:06:37Z</terms:created>
        <terms:description xml:lang="en">Social isolation often produces abnormal behavioral and physiological changes in both humans and nonhuman animals.</terms:description>
        <oboInOwl:hasExactSynonym xml:lang="en">social isolation</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">social isolation process</rdfs:label>
        <skos:prefLabel xml:lang="en">social isolation</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004013"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An emotion process involving voluntary or involuntary absence of contact with others.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/social-isolation</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004014 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004014">
