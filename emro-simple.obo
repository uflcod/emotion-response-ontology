property_value: terms:description "The Emotion Response Ontology represents emotions as behavioral responses to a situation or event, or internal process which evokes positive feelings, negative feelings, or surprise (i.e., emotional experiences)." xsd:string
property_value: terms:license http://creativecommons.org/licenses/by/4.0/
property_value: terms:title "Emotion Response Ontology" xsd:string

[Term]
id: EMRO:0000000
name: emotion process
def: "A behavioral response that includes overt action, cognitive response, verbal response, or physiological reaction in response to a situation or event, or internal process which evokes positive feelings, negative feelings, or surprise (i.e., emotional experiences)." []
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899
property_value: terms:contributor https://orcid.org/0000-0001-9990-8331
property_value: terms:contributor https://orcid.org/0000-0002-0766-8455
property_value: terms:created "2025-11-24T20:50:19Z" xsd:dateTime

[Term]
id: EMRO:0000001
name: phenomenal cognitive experience
def: "A cognitive process during which an organism is aware of something either internal or external to itself." [] {IAO:0000119="https://dictionary.apa.org/consciousness"}
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899
property_value: terms:contributor https://orcid.org/0000-0001-9990-8331
property_value: terms:contributor https://orcid.org/0000-0002-0766-8455
property_value: terms:created "2025-11-24T20:52:17Z" xsd:dateTime

[Term]
id: EMRO:0000002
name: emotional experience (feeling)
def: "A phenomenal cognitive experience evaluated as pleasant or unpleasant." [] {IAO:0000119="https://dictionary.apa.org/feeling"}
is_a: EMRO:0000001 ! phenomenal cognitive experience
relationship: part_of EMRO:0000000 ! emotion process
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899
property_value: terms:contributor https://orcid.org/0000-0001-9990-8331
property_value: terms:contributor https://orcid.org/0000-0002-0766-8455
property_value: terms:created "2025-11-24T20:52:39Z" xsd:dateTime

[Term]
id: EMRO:0000003
name: anxiety process
def: "An emotion process that is a response that occurs more distally in time or physical space with regard to threatening stimuli. Anxiety typically involves worrying about experiencing threats that could or will be experienced in the future." []
is_a: EMRO:0000000 ! emotion process
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899
property_value: terms:contributor https://orcid.org/0000-0001-9990-8331
property_value: terms:contributor https://orcid.org/0000-0002-0766-8455
property_value: terms:created "2025-11-24T20:56:47Z" xsd:dateTime

[Term]
id: EMRO:0000004
name: fear process
def: "An emotion process that is an in-the-moment response to a perceived threat. Fear is typically associated with organized, robust visceral arousal." []
is_a: EMRO:0000000 ! emotion process
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899
property_value: terms:contributor https://orcid.org/0000-0001-9990-8331
property_value: terms:contributor https://orcid.org/0000-0002-0766-8455
property_value: terms:created "2025-11-24T20:57:08Z" xsd:dateTime

[Term]
id: EMRO:0000005
name: sensory experience
def: "A phenomenal cognitive experience produced by the parts of the nervous sysem involved in awareness of the external world (i.e., external stimulus) or changes to internal organs. A sensory experience does not necessarily entail the existence phenomenon experiences (e.g., hallucinations)." [] {IAO:0000119="https://dictionary.apa.org/sensation"}
is_a: EMRO:0000001 ! phenomenal cognitive experience
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899
property_value: terms:contributor https://orcid.org/0000-0001-9990-8331
property_value: terms:contributor https://orcid.org/0000-0002-0766-8455
property_value: terms:created "2025-11-24T20:59:47Z" xsd:dateTime

[Term]
id: EMRO:0000006
name: motoric response to emotion
def: "A motor behavior that happens as a response to an emotion process. The motoric response includes muscle contractions that may move parts of the body or prevent the body from moving (e.g., freezing)." []
is_a: EMRO:0000007 ! psychophysiological response to emotion
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899
property_value: terms:contributor https://orcid.org/0000-0001-9990-8331
property_value: terms:contributor https://orcid.org/0000-0002-0766-8455
property_value: terms:created "2025-11-24T21:02:42Z" xsd:dateTime

[Term]
id: EMRO:0000007
name: psychophysiological response to emotion
def: "A psychophysiological process that is part of an emotion process." []
relationship: part_of EMRO:0000000 ! emotion process
relationship: RO:0002410 EMRO:0000000 ! causally related to emotion process
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899
property_value: terms:contributor https://orcid.org/0000-0001-9990-8331
property_value: terms:contributor https://orcid.org/0000-0002-0766-8455
property_value: terms:created "2025-11-24T21:10:13Z" xsd:dateTime

