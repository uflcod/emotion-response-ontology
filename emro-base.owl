                <owl:someValuesFrom rdf:resource="https://w3id.org/emotion-response-ontology/EMRO_0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An unpleasant sensory and emotional experience associated with, or resembling that associated with, actual or potential tissue damage.</obo:IAO_0000115>
        <rdfs:comment>Pain is a term from the pain ontology.</rdfs:comment>
    </owl:Class>
    


