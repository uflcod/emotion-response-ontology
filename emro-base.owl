        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T16:35:23Z</terms:created>
        <oboInOwl:hasExactSynonym xml:lang="en">introversion</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">introversion trait characteristic</rdfs:label>
        <skos:prefLabel xml:lang="en">introversion</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004007"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A personality trait characteristic involving an orientation toward the internal private world of one’s self and one’s inner thoughts and feelings, rather than toward the outer world of people and things.</owl:annotatedTarget>
