            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Sweat screation that happens as a response to an emotion process.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
