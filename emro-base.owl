        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T17:06:26Z</terms:created>
        <oboInOwl:hasExactSynonym>creativity</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">creativity</rdfs:label>
        <skos:prefLabel xml:lang="en">creativity</skos:prefLabel>
