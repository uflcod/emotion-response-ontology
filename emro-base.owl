    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004011"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A cognitive process during which an individual produces or develops original work, theories, techniques, or thoughts.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/creativity</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004012 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0000000"/>
        <obo:IAO_0000115 xml:lang="en">An emotion process that is a physiological or psychological response to internal or external stressors.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">stress process (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T17:50:36Z</terms:created>
        <terms:description xml:lang="en">Stress involves changes affecting nearly every system of the body, influencing how people feel and behave.</terms:description>
        <oboInOwl:hasExactSynonym xml:lang="en">stress</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">stress process</rdfs:label>
        <skos:prefLabel xml:lang="en">stress</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004012"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">An emotion process that is a physiological or psychological response to internal or external stressors.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/stress</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004013 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004013">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0000000"/>
        <obo:IAO_0000115 xml:lang="en">An emotion process involving voluntary or involuntary absence of contact with others.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">social isolation process (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
