    <!-- http://purl.obolibrary.org/obo/EMRO_0004015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004000"/>
        <obo:IAO_0000115 xml:lang="en">A personality trait characteristic involving restraint in engaging with the world combined with a tendency to scrutinize the environment for potential threats and to avoid or withdraw from unfamiliar situations or people.</obo:IAO_0000115>
        <obo:IAO_0000589 xml:lang="en">behavioral inhibition trait characteristic (EMRO)</obo:IAO_0000589>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
