    <!-- https://w3id.org/emotion-response-ontology/**pain -->

    <owl:Class rdf:about="https://w3id.org/emotion-response-ontology/**pain">
        <rdfs:subClassOf rdf:resource="https://w3id.org/emotion-response-ontology/EMRO_0000005"/>
        <rdfs:subClassOf>
            <owl:Restriction>
