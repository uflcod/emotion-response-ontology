        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-06-08T20:20:37Z</terms:created>
        <oboInOwl:hasExactSynonym xml:lang="en">behavioral inhibition</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym xml:lang="en">behavioural inhibition</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">behavioral inhibition trait characteristic</rdfs:label>
        <skos:prefLabel xml:lang="en">behavioral inhibition</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/EMRO_0004015"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A personality trait characteristic involving restraint in engaging with the world combined with a tendency to scrutinize the environment for potential threats and to avoid or withdraw from unfamiliar situations or people.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/behavioral-inhibition</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/EMRO_0004016 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/EMRO_0004016">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/EMRO_0000000"/>
