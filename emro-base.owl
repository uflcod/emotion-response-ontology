        <oboInOwl:hasExactSynonym xml:lang="en">loneliness</oboInOwl:hasExactSynonym>
        <rdfs:label xml:lang="en">loneliness process</rdfs:label>
        <skos:prefLabel xml:lang="en">loneliness</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
