[Term]
id: EMRO:0003001
name: self-conscious emotional experience
def: "An emotional experience generated when events reflect on the worth or value of the self in one’s own or others’ eyes." [] {IAO:0000119="https://dictionary.apa.org/self-conscious-emotion"}
is_a: EMRO:0000002 ! emotional experience
property_value: IAO:0000589 "self-conscious emotional experience (EMRO)" xsd:string
property_value: terms:contributor https://orcid.org/0009-0002-7282-0836
property_value: terms:created "2026-05-04T20:44:41Z" xsd:dateTime

[Term]
id: EMRO:0003002
name: embarrassment
def: "A self-conscious emotional experience in which a person feels awkward or flustered in other people’s company or because of the attention of others, as, for example, when being observed engaging in actions that are subject to mild disapproval from others." [] {IAO:0000119="https://dictionary.apa.org/embarrassment"}
is_a: EMRO:0003001 ! self-conscious emotional experience
property_value: IAO:0000589 "embarrassment (EMRO)" xsd:string
property_value: terms:contributor https://orcid.org/0009-0002-7282-0836
property_value: terms:created "2026-05-04T20:47:27Z" xsd:dateTime

[Term]
id: EMRO:0003003
name: shame
def: "A highly unpleasant self-conscious emotional experience arising from the sense of there being something dishonorable, immodest, or indecorous in one’s own conduct or circumstances." [] {IAO:0000119="https://dictionary.apa.org/shame"}
is_a: EMRO:0003001 ! self-conscious emotional experience
property_value: IAO:0000589 "shame (EMRO)" xsd:string
property_value: terms:contributor https://orcid.org/0009-0002-7282-0836
property_value: terms:created "2026-05-04T20:55:14Z" xsd:dateTime

[Term]
id: EMRO:0003004
name: pride
def: "A self-conscious emotional experience that occurs when a goal has been attained and one’s achievement has been recognized and approved by others." [] {IAO:0000119="https://dictionary.apa.org/pride"}
is_a: EMRO:0003001 ! self-conscious emotional experience
property_value: IAO:0000589 "pride (EMRO)" xsd:string
property_value: terms:contributor https://orcid.org/0009-0002-7282-0836
property_value: terms:created "2026-05-04T20:57:07Z" xsd:dateTime

[Term]
id: EMRO:0003005
name: guilt
def: "A self-conscious emotional experience characterized by a painful appraisal of having done (or thought) something that is wrong and often by a readiness to take action designed to undo or mitigate this wrong." [] {IAO:0000119="https://dictionary.apa.org/guilt"}
is_a: EMRO:0003001 ! self-conscious emotional experience
