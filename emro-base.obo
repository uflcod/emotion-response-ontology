[Term]
id: http://purl.bioontology.org/ontology/EMRO/0000015
name: syncope response to emotion
def: "A transient loss of consciousness and postural tone that happens as a result of an emotion process." [] {IAO:0000119="Adapted from MeSH definition for syncope. See https://meshb.nlm.nih.gov/record/ui?ui=D013575 or http://purl.bioontology.org/ontology/SNOMEDCT/271594007."}
synonym: "fainting" BROAD []
synonym: "fainting response to emotion" EXACT []
synonym: "syncope" BROAD []
synonym: "vasovagal syncope" RELATED []
is_a: http://purl.bioontology.org/ontology/EMRO/0000007 ! psychophysiological response to emotion
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899
